# ============================================
# Law Organizer - Environment Configuration
# Production-Ready Template
# ============================================
# Copy this file to .env and configure for your environment
# NEVER commit .env files to version control
# ============================================

# ============================================
# APPLICATION
# ============================================
NODE_ENV=production
PORT=3000
APP_URL=https://laworganizer.ua
BASE_DOMAIN=law-organizer.ua

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Options: postgres (production), sqlite (development)
DB_TYPE=postgres
DB_NAME=law_organizer
DB_HOST=postgres-postgresql.database.svc.cluster.local
DB_PORT=5432
DB_USER=law_organizer_user
# SECURITY: Use strong password (min 32 chars)
# Generate: openssl rand -base64 32
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_MIN_32_CHARS
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true

# Admin credentials (for initial setup only)
DB_ADMIN_USER=postgres
DB_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# Connection pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_ENABLED=true
REDIS_HOST=redis-master.database.svc.cluster.local
REDIS_PORT=6379
# SECURITY: Use strong password
# Generate: openssl rand -base64 32
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_MIN_32_CHARS
REDIS_DB=0
REDIS_PREFIX=law-org:
REDIS_TLS=true

# ============================================
# JWT CONFIGURATION
# ============================================
# SECURITY: Generate unique secrets for each environment
# Generate: openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64_MIN_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64_MIN_64_CHARS
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d
JWT_ISSUER=law-organizer
JWT_AUDIENCE=law-organizer-users

# ============================================
# STRIPE CONFIGURATION (International Payments)
# ============================================
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# Product Price IDs
STRIPE_PRICE_BASIC=price_CHANGE_ME
STRIPE_PRICE_PROFESSIONAL=price_CHANGE_ME
STRIPE_PRICE_ENTERPRISE=price_CHANGE_ME

# ============================================
# WAYFORPAY CONFIGURATION (Ukrainian Payments)
# ============================================
# Get from: https://my.wayforpay.com/
WAYFORPAY_MERCHANT_ACCOUNT=CHANGE_ME_MERCHANT_ID
WAYFORPAY_MERCHANT_SECRET_KEY=CHANGE_ME_SECRET_KEY
WAYFORPAY_API_URL=https://secure.wayforpay.com/pay
WAYFORPAY_CALLBACK_URL=https://laworganizer.ua/api/payments/wayforpay/callback

# ============================================
# STORAGE CONFIGURATION
# ============================================
# Options: s3 (production), local (development)
STORAGE_PROVIDER=s3

# AWS S3 / MinIO Configuration
AWS_S3_BUCKET=law-organizer-uploads
AWS_ACCESS_KEY_ID=CHANGE_ME_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=CHANGE_ME_SECRET_KEY
AWS_REGION=eu-north-1
AWS_ENDPOINT=https://s3.eu-north-1.amazonaws.com

# Local Storage (development only)
LOCAL_STORAGE_DIR=./storage
LOCAL_STORAGE_URL=http://localhost:3000/storage

# ============================================
# CDN CONFIGURATION
# ============================================
CDN_ENABLED=true
CDN_PROVIDER=cloudflare
CDN_DOMAIN=cdn.laworganizer.ua
CDN_BASE_URL=https://cdn.laworganizer.ua

# Cloudflare
CLOUDFLARE_ZONE_ID=CHANGE_ME_ZONE_ID
CLOUDFLARE_API_TOKEN=CHANGE_ME_API_TOKEN

# Fastly (alternative)
FASTLY_SERVICE_ID=
FASTLY_API_KEY=

# ============================================
# EMAIL CONFIGURATION
# ============================================
# SMTP settings for transactional emails
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
# SECURITY: Use app-specific password or API key
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM="Law Organizer <noreply@laworganizer.ua>"
SMTP_REPLY_TO="support@laworganizer.ua"

# Email templates
EMAIL_TEMPLATES_DIR=./templates/email

# ============================================
# CORS CONFIGURATION
# ============================================
# SECURITY: Specify exact origins in production
ALLOWED_ORIGINS=https://laworganizer.ua,https://www.laworganizer.ua,https://api.laworganizer.ua
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# ============================================
# RATE LIMITING
# ============================================
# General API rate limit
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Stricter limits for auth endpoints
AUTH_THROTTLE_TTL=60000
AUTH_THROTTLE_LIMIT=5

# ============================================
# SECURITY SETTINGS
# ============================================
# PII Encryption (GDPR compliance)
ENCRYPT_PII=true
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_32_HEX_CHARS_64_CHARS_TOTAL

# Password hashing
BCRYPT_SALT_ROUNDS=12

# Session settings
SESSION_SECRET=CHANGE_ME_SESSION_SECRET_MIN_32_CHARS
SESSION_MAX_AGE=86400000

# ============================================
# MONITORING & OBSERVABILITY
# ============================================
# Sentry (Error Tracking)
SENTRY_DSN=https://CHANGE_ME@sentry.io/CHANGE_ME
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# New Relic (APM)
NEW_RELIC_LICENSE_KEY=CHANGE_ME_LICENSE_KEY
NEW_RELIC_APP_NAME=Law Organizer Production
NEW_RELIC_LOG_LEVEL=info

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_DIR=./logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d
LOG_ERROR_MAX_FILES=30d
LOG_CONSOLE_ONLY=false

# Request logging
ENABLE_REQUEST_LOGGING=false
ENABLE_METHOD_LOGGING=true
LOGGING_PERFORMANCE_THRESHOLD=1000

# ============================================
# FEATURES
# ============================================
ENABLE_RLS=true
ENABLE_AUDIT_LOGGING=true
ENABLE_WEBHOOKS=true
ENABLE_2FA=true
ENABLE_EMAIL_VERIFICATION=true

# ============================================
# DATABASE OPTIMIZATION
# ============================================
SLOW_QUERY_THRESHOLD=1000
ENABLE_QUERY_LOGGING=false
QUERY_CACHE_TTL=300

# ============================================
# AUDIT & COMPLIANCE
# ============================================
# Retention period in days (7 years for legal compliance)
AUDIT_RETENTION_DAYS=2555

# ============================================
# BACKGROUND JOBS
# ============================================
WORKER_CONCURRENCY=5
JOB_TIMEOUT=300000

# ============================================
# DEVELOPMENT TOOLS (Disable in production)
# ============================================
# PgAdmin (Remove in production)
PGADMIN_EMAIL=
PGADMIN_PASSWORD=

# Debug mode (NEVER enable in production)
DEBUG=false
DEBUG_SQL=false

# ============================================
# DOCKER/CONTAINER CONFIGURATION
# ============================================
DOCKER_REGISTRY=ghcr.io
IMAGE_TAG=latest

# ============================================
# KUBERNETES CONFIGURATION
# ============================================
K8S_NAMESPACE=law-organizer
K8S_REPLICAS_BACKEND=3
K8S_REPLICAS_FRONTEND=2
K8S_REPLICAS_WORKER=2

# ============================================
# BACKUP CONFIGURATION
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=law-organizer-backups
BACKUP_ENCRYPTION_KEY=CHANGE_ME_BACKUP_ENCRYPTION_KEY

# ============================================
# SSL/TLS CONFIGURATION
# ============================================
SSL_ENABLED=true
SSL_CERT_PATH=/etc/ssl/certs/tls.crt
SSL_KEY_PATH=/etc/ssl/certs/tls.key
SSL_CA_PATH=/etc/ssl/certs/ca.crt

# ============================================
# HEALTH CHECK
# ============================================
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_TIMEOUT=5000

# ============================================
# API DOCUMENTATION
# ============================================
SWAGGER_ENABLED=false
SWAGGER_PATH=/api/docs
SWAGGER_USERNAME=admin
SWAGGER_PASSWORD=CHANGE_ME_SWAGGER_PASSWORD
