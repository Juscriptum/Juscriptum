# ============================================
# Law Organizer - Staging Environment Template
# Recommended baseline for the reduced day-one scope.
# Do not commit real staging secrets.
# ============================================

# ============================================
# APPLICATION
# ============================================
NODE_ENV=production
PORT=3000
APP_URL=https://staging.laworganizer.ua
BASE_DOMAIN=staging.laworganizer.ua
ALLOWED_ORIGINS=https://staging.laworganizer.ua
RUN_SCHEDULED_JOBS=false
DB_SYNC=false

# ============================================
# DATABASE
# ============================================
DB_TYPE=postgres
DB_HOST=postgres
DB_PORT=5432
DB_USER=law_organizer
DB_PASSWORD=CHANGE_ME_STAGING_DB_PASSWORD
DB_NAME=law_organizer
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=law_organizer
DATABASE_PASSWORD=CHANGE_ME_STAGING_DB_PASSWORD
DATABASE_NAME=law_organizer

# ============================================
# REDIS
# ============================================
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STAGING_REDIS_PASSWORD
REDIS_PREFIX=law-org:staging:

# ============================================
# JWT / SECURITY
# ============================================
JWT_SECRET=CHANGE_ME_GENERATE_BASE64_64_MIN_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_BASE64_64_MIN_64_CHARS
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d
PLATFORM_ADMIN_JWT_SECRET=CHANGE_ME_GENERATE_BASE64_64_MIN_64_CHARS
PLATFORM_ADMIN_JWT_ACCESS_TOKEN_EXPIRY=15m
PLATFORM_ADMIN_JWT_REFRESH_TOKEN_EXPIRY=7d
PLATFORM_ADMIN_JWT_MFA_TOKEN_EXPIRY=5m
# Optional bootstrap secret for the very first platform owner only.
PLATFORM_ADMIN_BOOTSTRAP_TOKEN=
PLATFORM_ADMIN_MFA_ISSUER=Law Organizer Platform Admin
ENCRYPT_PII=true
ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHAR_KEY

# ============================================
# STORAGE
# ============================================
STORAGE_PROVIDER=s3
AWS_S3_BUCKET=law-organizer-staging
AWS_ACCESS_KEY_ID=CHANGE_ME_STAGING_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=CHANGE_ME_STAGING_SECRET_KEY
AWS_REGION=eu-central-1
AWS_ENDPOINT=https://minio.staging.internal

# ============================================
# EMAIL
# Essential for password reset and launch-critical communication.
# ============================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=staging-smtp-user
SMTP_PASSWORD=CHANGE_ME_STAGING_SMTP_PASSWORD
SMTP_FROM="Law Organizer Staging <noreply@staging.laworganizer.ua>"
SMTP_REPLY_TO=support@staging.laworganizer.ua

# ============================================
# MALWARE SCANNING / PDF RUNTIME
# Staging should prove the real target-style scanner path.
# ============================================
MALWARE_SCANNER_MODE=clamav_command
MALWARE_SCANNER_COMMAND=clamdscan
MALWARE_SCANNER_TIMEOUT_MS=15000

# ============================================
# TRUST PROVIDERS
# Keep in stub mode for the reduced day-one scope.
# ============================================
ACSK_TRUST_MODE=stub
DIIA_TRUST_MODE=stub
BANKID_NBU_MODE=stub

# ============================================
# PAYMENTS
# Leave unset unless self-serve billing is explicitly put back in scope.
# ============================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=
WAYFORPAY_MERCHANT_ACCOUNT=
WAYFORPAY_MERCHANT_SECRET_KEY=
WAYFORPAY_API_URL=

# ============================================
# EXTERNAL DATA / REGISTRY AUTO-UPDATES
# Enable these only on the dedicated worker runtime.
# ============================================
EXTERNAL_DATASET_URL_ASVP=
EXTERNAL_DATA_URLS_ASVP=
EXTERNAL_DATASET_URL_COURT_STAN=
EXTERNAL_DATA_URLS_COURT_STAN=
EXTERNAL_DATASET_URL_COURT_DATES=
EXTERNAL_DATA_URLS_COURT_DATES=
EXTERNAL_DATASET_URL_REESTR=
EXTERNAL_DATA_URLS_REESTR=

# ============================================
# LOGGING / MONITORING
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json
SENTRY_DSN=
